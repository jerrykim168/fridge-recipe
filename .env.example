# Copy this file to .env.local and fill in your key.
#   cp .env.example .env.local

# OpenRouter API key (server-side only — never exposed to the browser).
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Vision-capable model for ingredient recognition. Swap freely, e.g.:
#   openai/gpt-4o-mini            (default — reliable, cheap vision)
#   google/gemini-flash-1.5      (fast, low cost)
#   qwen/qwen-2-vl-72b-instruct  (open model with strong vision)
OPENROUTER_VISION_MODEL=openai/gpt-4o-mini

# Text model for recipe generation (Step 2). Swap freely, e.g.:
#   deepseek/deepseek-chat        (default — cheap, strong Korean output)
#   deepseek/deepseek-r1          (reasoning model; strips <think> — pricier/slower)
#   openai/gpt-4o-mini            (most reliable JSON, higher cost)
OPENROUTER_RECIPE_MODEL=deepseek/deepseek-chat

# Optional attribution headers for OpenRouter.
OPENROUTER_APP_URL=http://localhost:3000
OPENROUTER_APP_TITLE=냉장고를 부탁해

# Supabase project (Step 3 — auth + saved recipes storage; see lib/db/supabase.ts).
# SERVICE_ROLE_KEY bypasses row-level security — server-side only, never expose to the browser.
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
